{
  "expo": {
    "name": "RTKM",
    "slug": "rtkm",
    "scheme": "rtkm",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.truncate.rtkm"
    },
    "android": {
      "package": "com.truncate.rtkm",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      }
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-sqlite",
      "expo-web-browser",
      "expo-notifications",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "RTKM uses your location to show distance to a petrol pump and open it in Maps."
        }
      ]
    ]
  }
}
