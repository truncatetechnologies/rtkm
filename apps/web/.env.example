# RTKM web app — environment template.
# Copy to .env.local and fill in. NEVER commit .env.local (it is gitignored).

# ---- Core (required) ----
MONGODB_URI=mongodb://127.0.0.1:27017/rtkm
NEXTAUTH_SECRET=change-me-to-a-long-random-string
NEXTAUTH_URL=http://localhost:3000
# HS256 secret for phone+PIN tokens (mobile + owner web cookie)
MOBILE_JWT_SECRET=change-me-to-a-long-random-string

# ---- Google (admin login + Gmail import; same OAuth web client) ----
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Comma-separated Gmail addresses allowed to sign in as Google admin
ADMIN_EMAILS=
# Optional: allowed audiences for mobile Google sign-in (comma-separated)
GOOGLE_MOBILE_CLIENT_IDS=

# ---- Gmail import ----
# AES key encrypting the stored Gmail refresh token. SET THIS BEFORE connecting Gmail.
# If blank, falls back to MOBILE_JWT_SECRET. Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
GMAIL_TOKEN_SECRET=
# Optional override; defaults to ${NEXTAUTH_URL}/api/integrations/gmail/callback
# GMAIL_REDIRECT_URI=

# ---- Geocoding (optional; defaults to free OSM Nominatim) ----
GOOGLE_GEOCODING_KEY=

# ---- Web push (optional) ----
# Generate a pair: node -e "console.log(require('web-push').generateVAPIDKeys())"
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_SUBJECT=mailto:you@example.com

# ---- Background Gmail scan cron (optional) ----
# Bearer secret guarding /api/cron/check-gmail
CRON_SECRET=
